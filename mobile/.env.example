# TravelCanvas Mobile — API 키 (선택). 없으면 데모 모드로 동작합니다.
# Expo 클라이언트에서 접근하려면 반드시 EXPO_PUBLIC_ 접두사를 사용하세요.
# 앱 내 Settings 탭에서 직접 입력할 수도 있습니다(AsyncStorage 저장).

# Anthropic (Claude) — 글 분석 기본 엔진
EXPO_PUBLIC_ANTHROPIC_API_KEY=
EXPO_PUBLIC_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (GPT) — 대체 엔진
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_OPENAI_MODEL=gpt-4o-mini

# Unsplash — 이미지 검색
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=

# 분석 엔진 선택: auto | anthropic | openai
EXPO_PUBLIC_LLM_PROVIDER=auto
